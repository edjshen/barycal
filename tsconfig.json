{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022", "webworker"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vitest/globals"],
    "paths": {
      "@/*": ["./*"],
      "@edjshen/e2e-kit": ["./e2e-kit/src/index.ts"],
      "@edjshen/e2e-kit/config": ["./e2e-kit/src/config.ts"],
      "@edjshen/e2e-kit/*": ["./e2e-kit/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "lib/mayfly/shared/**/*.test.js",
    "capacitor.config.ts",
    "native",
    "ios",
    "android"
  ]
}
